# ─────────────────────────────────────────────
# NextAuth.js core
# ─────────────────────────────────────────────

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# The canonical URL of your app (no trailing slash)
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Email provider (magic links)
# ─────────────────────────────────────────────

# Option A: Ethereal (free, local testing — no real emails sent)
EMAIL_SERVER_HOST=smtp.ethereal.email
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-ethereal-user
EMAIL_SERVER_PASSWORD=your-ethereal-password
EMAIL_FROM=noreply@example.com

# Option B: Resend (https://resend.com — free tier available)
# EMAIL_SERVER_HOST=smtp.resend.com
# EMAIL_SERVER_PORT=465
# EMAIL_SERVER_USER=resend
# EMAIL_SERVER_PASSWORD=re_your_api_key_here
# EMAIL_FROM=noreply@yourdomain.com

# ─────────────────────────────────────────────
# Database (SQLite — local file, no cloud setup)
# ─────────────────────────────────────────────

SQLITE_DB_PATH=./data/cardgame.db

# ─────────────────────────────────────────────
# TODO: Add OAuth providers (Google, Discord, etc.) in a future step
# TODO: Replace SQLite with a cloud DB (PlanetScale, Supabase) for production
# ─────────────────────────────────────────────

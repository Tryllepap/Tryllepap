# ── Session secret (REQUIRED) ──────────────────────────────────────────────
# Must be at least 32 characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# ── Vercel KV (optional for local dev — uses in-memory fallback if absent) ──
# Add these after running: vercel kv create tryllepap-db
# KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
# KV_REST_API_TOKEN=AXxxxx==
